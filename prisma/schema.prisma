// ═══════════════════════════════════════════════
// EduHire — Prisma Schema
// Database: PostgreSQL (Supabase)
// Auth: NextAuth.js
// ═══════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Supabase connection pooling
}

// ─── Enums ───────────────────────────────────

enum UserRole {
  TEACHER
  SCHOOL_ADMIN
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  VISITING_FACULTY
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  EXPIRED
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
}

enum Board {
  CBSE
  ICSE
  STATE_BOARD
  IB
  CAMBRIDGE
  OTHER
}

enum AvailabilityStatus {
  ACTIVELY_LOOKING
  OPEN_TO_OFFERS
  NOT_LOOKING
}

enum AlertFrequency {
  IMMEDIATE
  DAILY_DIGEST
  WEEKLY_DIGEST
}

enum RejectionReason {
  OVERQUALIFIED
  UNDERQUALIFIED
  POSITION_FILLED
  EXPERIENCE_MISMATCH
  LOCATION_MISMATCH
  SALARY_MISMATCH
  OTHER
}

enum InterviewType {
  VIDEO
  PHONE
  IN_PERSON
}

enum InterviewStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ─── User (single auth table for all roles) ──

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  name           String
  role           UserRole  @default(TEACHER)
  phone          String?
  avatarUrl      String?   @map("avatar_url")
  emailVerified  Boolean   @default(false) @map("email_verified")
  hashedPassword String?   @map("hashed_password") // null for OAuth users
  resetToken     String?   @map("reset_token")
  resetTokenExpiresAt DateTime? @map("reset_token_expires_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  teacherProfile TeacherProfile?
  schoolProfile  SchoolProfile?
  applications   Application[]
  savedJobs      SavedJob[]
  resumes        Resume[]
  jobPostings    JobPosting[]    // jobs this user posted
  jobAlerts      JobAlert[]
  statusChanges  ApplicationStatusHistory[]
  matchScores    AIMatchScore[]

  @@map("users")
}

// ─── Teacher Profile ─────────────────────────

model TeacherProfile {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @unique @map("user_id") @db.Uuid
  qualification      String?
  experience         String?             // e.g. "3-5 years"
  currentSchool      String?             @map("current_school")
  city               String?
  bio                String?             @db.Text
  subjects           String[]            // array of subjects they teach
  preferredBoards    String[]            @map("preferred_boards") // boards they prefer
  preferredGrades    String[]            @map("preferred_grades") // grade levels they prefer
  expectedSalary     Int?                @map("expected_salary")  // monthly in INR
  availabilityStatus AvailabilityStatus  @default(NOT_LOOKING) @map("availability_status")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences      Experience[]
  certifications   Certification[]

  @@index([city])
  @@index([subjects])
  @@map("teacher_profiles")
}

// ─── Experience (work history) ───────────────

model Experience {
  id               String         @id @default(uuid()) @db.Uuid
  teacherProfileId String         @map("teacher_profile_id") @db.Uuid
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  schoolName       String         @map("school_name")
  role             String
  startDate        DateTime       @map("start_date") @db.Timestamptz
  endDate          DateTime?      @map("end_date") @db.Timestamptz
  isCurrent        Boolean        @default(false) @map("is_current")
  description      String?        @db.Text
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  @@index([teacherProfileId])
  @@map("experiences")
}

// ─── Certification ───────────────────────────

model Certification {
  id               String         @id @default(uuid()) @db.Uuid
  teacherProfileId String         @map("teacher_profile_id") @db.Uuid
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  name             String
  issuedBy         String         @map("issued_by")
  issuedAt         DateTime       @map("issued_at") @db.Timestamptz
  expiresAt        DateTime?      @map("expires_at") @db.Timestamptz
  credentialId     String?        @map("credential_id")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  @@index([teacherProfileId])
  @@map("certifications")
}

// ─── School Profile ──────────────────────────

model SchoolProfile {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  schoolName String   @map("school_name")
  city       String
  board      Board
  address    String?  @db.Text
  website    String?
  about      String?  @db.Text
  logoUrl    String?  @map("logo_url")
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPostings JobPosting[]

  @@index([city])
  @@index([board])
  @@index([verified])
  @@map("school_profiles")
}

// ─── Job Posting ─────────────────────────────

model JobPosting {
  id          String    @id @default(uuid()) @db.Uuid
  schoolId    String    @map("school_id") @db.Uuid
  postedBy    String    @map("posted_by") @db.Uuid
  title       String
  subject     String
  board       Board
  gradeLevel  String    @map("grade_level") // e.g. "9-12", "Pre-K", "1-5"
  jobType     JobType   @default(FULL_TIME) @map("job_type")
  experience  String?   // e.g. "3-5 years"
  salaryMin   Int?      @map("salary_min")  // monthly INR
  salaryMax   Int?      @map("salary_max")
  description String    @db.Text
  status      JobStatus @default(ACTIVE)
  postedAt    DateTime  @default(now()) @map("posted_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  views       Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  school       SchoolProfile    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  poster       User             @relation(fields: [postedBy], references: [id])
  requirements JobRequirement[]
  benefits     JobBenefit[]
  applications Application[]
  savedBy      SavedJob[]
  matchScores  AIMatchScore[]

  // Indexes for filtering & search
  @@index([status])
  @@index([subject])
  @@index([board])
  @@index([gradeLevel])
  @@index([salaryMin, salaryMax])
  @@index([postedAt(sort: Desc)])
  @@index([schoolId])
  @@index([status, postedAt(sort: Desc)]) // composite: active jobs newest first
  @@map("job_postings")
}

// ─── Job Requirements (one per row) ──────────

model JobRequirement {
  id        String @id @default(uuid()) @db.Uuid
  jobId     String @map("job_id") @db.Uuid
  text      String
  sortOrder Int    @default(0) @map("sort_order")

  // Relations
  job JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_requirements")
}

// ─── Job Benefits (one per row) ──────────────

model JobBenefit {
  id        String @id @default(uuid()) @db.Uuid
  jobId     String @map("job_id") @db.Uuid
  text      String
  sortOrder Int    @default(0) @map("sort_order")

  // Relations
  job JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_benefits")
}

// ─── Application ─────────────────────────────

model Application {
  id          String            @id @default(uuid()) @db.Uuid
  jobId       String            @map("job_id") @db.Uuid
  applicantId String            @map("applicant_id") @db.Uuid
  coverLetter String?           @map("cover_letter") @db.Text
  resumeId         String?              @map("resume_id") @db.Uuid
  status           ApplicationStatus    @default(PENDING)
  schoolNotes      String?              @map("school_notes") @db.Text // internal notes
  rejectionReason  RejectionReason?     @map("rejection_reason")
  appliedAt        DateTime             @default(now()) @map("applied_at") @db.Timestamptz
  reviewedAt       DateTime?            @map("reviewed_at") @db.Timestamptz
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  job            JobPosting              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant      User                    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  resume         Resume?                 @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  statusHistory  ApplicationStatusHistory[]
  interview      Interview?

  // Prevent duplicate applications
  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
  @@index([status])
  @@index([appliedAt(sort: Desc)])
  @@map("applications")
}

// ─── Resume (file uploads) ───────────────────

model Resume {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  fileUrl       String   @map("file_url")  // Supabase Storage URL
  fileName      String   @map("file_name")
  fileSize      Int      @map("file_size") // bytes
  isGenerated   Boolean  @default(false) @map("is_generated")
  template      String?  // "ats-friendly", "modern", "minimal" for generated resumes
  generatedData Json?    @map("generated_data") // metadata about what was used to generate
  uploadedAt    DateTime @default(now()) @map("uploaded_at") @db.Timestamptz

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId])
  @@map("resumes")
}

// ─── Saved Jobs (bookmarks) ──────────────────

model SavedJob {
  id      String   @id @default(uuid()) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  jobId   String   @map("job_id") @db.Uuid
  savedAt DateTime @default(now()) @map("saved_at") @db.Timestamptz

  // Relations
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId]) // can't save the same job twice
  @@index([userId])
  @@map("saved_jobs")
}

// ─── Job Alert ───────────────────────────

model JobAlert {
  id             String          @id @default(uuid()) @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  name           String          // e.g. "Math jobs in Bangalore"
  subject        String?         // filter by subject
  city           String?         // filter by city
  board          Board?          // CBSE, ICSE, etc
  gradeLevel     String?         @map("grade_level") // e.g. "9-12"
  jobType        JobType?        @map("job_type")
  salaryMin      Int?            @map("salary_min")
  salaryMax      Int?            @map("salary_max")
  frequency      AlertFrequency  @default(DAILY_DIGEST)
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertHistory   AlertHistory[]

  @@index([userId])
  @@index([isActive])
  @@map("job_alerts")
}

// ─── Alert History ───────────────────────

model AlertHistory {
  id             String          @id @default(uuid()) @db.Uuid
  alertId        String          @map("alert_id") @db.Uuid
  jobIds         String[]        @map("job_ids") @db.Uuid // jobs sent in this digest
  sentAt         DateTime        @default(now()) @map("sent_at") @db.Timestamptz
  openedAt       DateTime?       @map("opened_at")
  clickedAt      DateTime?       @map("clicked_at")

  // Relations
  alert          JobAlert        @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([sentAt(sort: Desc)])
  @@map("alert_history")
}

// ─── Application Status History (audit trail) ─

model ApplicationStatusHistory {
  id              String            @id @default(uuid()) @db.Uuid
  applicationId   String            @map("application_id") @db.Uuid
  fromStatus      ApplicationStatus @map("from_status")
  toStatus        ApplicationStatus @map("to_status")
  changedBy       String            @map("changed_by") @db.Uuid
  changedAt       DateTime          @default(now()) @map("changed_at") @db.Timestamptz
  note            String?           @db.Text
  rejectionReason RejectionReason?  @map("rejection_reason")

  // Relations
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedByUser User        @relation(fields: [changedBy], references: [id])

  @@index([applicationId])
  @@index([changedAt(sort: Desc)])
  @@map("application_status_history")
}

// ─── Interview (Phase 4) ──────────────────────

model Interview {
  id            String          @id @default(uuid()) @db.Uuid
  applicationId String          @unique @map("application_id") @db.Uuid
  scheduledAt   DateTime        @map("scheduled_at") @db.Timestamptz
  durationMins  Int             @default(30) @map("duration_mins")
  type          InterviewType   @default(VIDEO)
  meetingLink   String?         @map("meeting_link")
  location      String?         // for IN_PERSON
  status        InterviewStatus @default(PENDING)
  schoolNotes   String?         @map("school_notes") @db.Text
  teacherNotes  String?         @map("teacher_notes") @db.Text
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@map("interviews")
}

// ─── AI Match Score (Phase 4) ─────────────────

model AIMatchScore {
  id          String   @id @default(uuid()) @db.Uuid
  jobId       String   @map("job_id") @db.Uuid
  applicantId String   @map("applicant_id") @db.Uuid
  score       Float    // 0.0 - 1.0
  breakdown   Json     // { subject, location, board, salary, experience } component scores
  explanation String   // "Matches your Math + Science skills in Chennai"
  computedAt  DateTime @default(now()) @map("computed_at") @db.Timestamptz

  // Relations
  job         JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant   User       @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([jobId, applicantId])
  @@index([jobId, score(sort: Desc)])
  @@map("ai_match_scores")
}
